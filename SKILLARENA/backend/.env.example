PORT=5000

# Local dev (MongoDB installed on this PC — default)
MONGODB_URI=mongodb://127.0.0.1:27017/Skill-Arena

# Atlas production / cloud — Database → Connect → Drivers in Atlas dashboard
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/Skill-Arena?retryWrites=true&w=majority

JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed frontend origins (Vercel + local dev)
CLIENT_URL=http://localhost:5173,https://skill-arena-smoky.vercel.app
# CLIENT_URLS=http://localhost:5173,https://your-app.vercel.app
PDF_SERVICE_URL=http://127.0.0.1:8001
# Production PDF service example:
# PDF_SERVICE_URL=https://skill-arena-pdf.onrender.com

# Optional server-wide Gemini fallback (users can also add their own keys in Profile)
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
# GEMINI_API_KEYS=key-one,key-two,key-three
# OPENAI_API_KEY=  # optional; only used if a user saves their own ChatGPT key in Profile
# OPENAI_MODEL=gpt-4o-mini
# AI_KEYS_SECRET=optional-separate-secret-for-encrypting-user-api-keys
